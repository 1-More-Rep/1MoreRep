// 1MoreRep — Prisma schema. Models grow phase-by-phase per the master plan.
// P0: AppMeta. P2: identity / auth / sessions / tokens / instance settings / audit.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Key/value application metadata (seed markers, schema bootstrap flags).
model AppMeta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Identity & auth (P2)
// ---------------------------------------------------------------------------

enum Role {
  SUPERADMIN
  ADMIN
  USER
}

enum UserStatus {
  INVITED // created by an admin, not yet activated
  ACTIVE
  DEACTIVATED // soft-disabled; cannot log in, data retained
}

enum TokenType {
  INVITE
  EMAIL_VERIFY
  LOGIN_LINK
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum UnitSystem {
  METRIC
  IMPERIAL
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique // stored normalized (lowercased, trimmed)
  emailVerifiedAt DateTime?
  passwordHash    String? // null until set; magic-link-only users are allowed
  role            Role       @default(USER)
  status          UserStatus @default(INVITED)

  displayName String
  avatarKey   String? // object-store key, never a public path
  unitSystem  UnitSystem @default(METRIC)
  timezone    String     @default("UTC") // drives tz-correct streak/league day keys

  // Public profile surface (leaderboards) — explicit, opt-in.
  isProfilePublic Boolean @default(false)
  publicHandle    String? @unique

  mustChangePassword Boolean   @default(false)
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  pendingEmail       String? // set during EMAIL_CHANGE, promoted on confirm

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  invitedById String?
  invitedBy   User?   @relation("Invites", fields: [invitedById], references: [id])
  invitees    User[]  @relation("Invites")

  sessions    Session[]
  authTokens  AuthToken[]
  auditEvents AuditEvent[] @relation("ActorEvents")
  exercises   Exercise[] // custom exercises owned by this user
  routines    Routine[]
  workouts    WorkoutSession[]
  prs         PersonalRecord[]
  sorenessReports  SorenessReport[]
  fatigueSnapshots MuscleFatigueSnapshot[]
  xpEvents         XpEvent[]
  stats            UserStats?
  leagueMemberships LeagueMembership[]
  notifications    Notification[]
  friendshipsSent     Friendship[] @relation("FriendRequester")
  friendshipsReceived Friendship[] @relation("FriendAddressee")
  blocksMade       Block[]      @relation("Blocker")
  blocksReceived   Block[]      @relation("Blocked")
  privacy          PrivacySettings?
  activityEvents   ActivityEvent[]
  bodyMetrics      BodyMetric[]
  progressPhotos   ProgressPhoto[]

  @@index([role])
  @@index([status])
}

model Session {
  id                String   @id // opaque random id (cookie = id.secret)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashedSecret      String // sha256 of the session secret; raw secret never stored
  createdAt         DateTime @default(now())
  lastUsedAt        DateTime @default(now())
  absoluteExpiresAt DateTime
  idleExpiresAt     DateTime
  ipHash            String? // HMAC(ip), not raw
  userAgent         String?
  label             String?

  @@index([userId])
  @@index([idleExpiresAt])
}

model AuthToken {
  id            String    @id @default(cuid())
  type          TokenType
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashedToken   String    @unique // sha256(rawToken); raw token only in the email link
  expiresAt     DateTime
  consumedAt    DateTime?
  payload       Json? // minimal, validated (e.g. { newEmail } for EMAIL_CHANGE)
  createdAt     DateTime  @default(now())
  requestIpHash String?

  @@index([userId, type])
  @@index([expiresAt])
}

/// Single-row (id = 1) instance configuration. Secrets stored AES-256-GCM encrypted.
model InstanceSettings {
  id Int @id @default(1)

  brandName         String     @default("1MoreRep")
  brandLogoKey      String?
  themeColor        String     @default("#e2553a")
  defaultUnitSystem UnitSystem @default(METRIC)

  allowSelfRegistration    Boolean @default(false)
  requireEmailVerification Boolean @default(true)

  // SMTP (password encrypted-at-rest)
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPasswordEnc String?
  smtpFrom        String?
  smtpSecure      Boolean @default(true)

  // LLM (Ollama default; remote keys encrypted)
  llmProvider String  @default("NONE") // NONE | OLLAMA | ANTHROPIC | OPENAI
  llmBaseUrl  String? @default("http://ollama:11434")
  llmModel    String? @default("llama3.1")
  llmApiKeyEnc String?
  llmTimeoutMs Int    @default(20000)

  // Web Push VAPID (private key encrypted)
  vapidPublicKey     String?
  vapidPrivateKeyEnc String?
  vapidSubject       String?

  updatedAt   DateTime @updatedAt
  updatedById String?
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("ActorEvents", fields: [actorId], references: [id], onDelete: SetNull)
  action     String // e.g. "auth.login.success", "user.invite", "settings.update"
  targetType String?
  targetId   String?
  metadata   Json? // redacted; never secrets/tokens
  ipHash     String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Exercise library & muscle taxonomy (P4)
// ---------------------------------------------------------------------------

/// Closed muscle set — mirrors src/domain/muscles/taxonomy.ts MUSCLES (keep in sync).
enum Muscle {
  CHEST
  FRONT_DELTS
  SIDE_DELTS
  REAR_DELTS
  BICEPS
  TRICEPS
  FOREARMS
  LATS
  TRAPS
  RHOMBOIDS
  LOWER_BACK
  ABS
  OBLIQUES
  QUADS
  HAMSTRINGS
  GLUTES
  CALVES
  ADDUCTORS
  NECK
}

enum Equipment {
  BARBELL
  DUMBBELL
  MACHINE
  CABLE
  BODYWEIGHT
  KETTLEBELL
  BAND
  EZ_BAR
  BALL
  OTHER
}

enum ExCategory {
  STRENGTH
  CARDIO
  OLYMPIC
  PLYOMETRICS
  POWERLIFTING
  STRETCHING
  STRONGMAN
  OTHER
}

enum Mechanic {
  COMPOUND
  ISOLATION
}

enum Force {
  PUSH
  PULL
  STATIC
}

enum MuscleRole {
  PRIMARY
  SECONDARY
}

model Exercise {
  id            String           @id @default(cuid())
  slug          String
  name          String
  category      ExCategory       @default(STRENGTH)
  equipment     Equipment        @default(OTHER)
  mechanic      Mechanic?
  force         Force?
  level         String?
  instructions  String[]
  iconKey       String           @default("dumbbell")
  defaultSets   Int              @default(3)
  defaultRepLow Int              @default(8)
  defaultRepHigh Int             @default(12)
  defaultRestSec Int             @default(120)
  isCustom      Boolean          @default(false)
  ownerId       String?
  owner         User?            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  source        String           @default("FREE_EXERCISE_DB")
  sourceId      String?          @unique // original dataset id; makes reseed idempotent
  muscleLinks   ExerciseMuscle[]
  routineItems  RoutineItem[]
  sessionEntries SessionEntry[]
  prs           PersonalRecord[]
  createdAt     DateTime         @default(now())

  @@index([ownerId])
  @@index([name])
  @@index([equipment])
}

/// Weighted muscle contribution (bench: CHEST 1.0, FRONT_DELTS 0.5, TRICEPS 0.4).
model ExerciseMuscle {
  id         String     @id @default(cuid())
  exerciseId String
  exercise   Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle     Muscle
  role       MuscleRole
  weight     Float

  @@unique([exerciseId, muscle])
  @@index([muscle])
}

// ---------------------------------------------------------------------------
// Workout logging (P5)
// ---------------------------------------------------------------------------

enum Goal {
  HYPERTROPHY
  STRENGTH
  ENDURANCE
  GENERAL
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum PrKind {
  EST_1RM
  BEST_WEIGHT
  BEST_VOLUME_SET
  BEST_REPS
  BEST_SESSION_VOLUME
}

/// A named, reusable workout template (ordered exercises with target schemes).
model Routine {
  id                String           @id @default(cuid())
  ownerId           String
  owner             User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name              String
  notes             String?
  goal              Goal?
  isArchived        Boolean          @default(false)
  generatedFromPlan Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  items             RoutineItem[]
  sessions          WorkoutSession[]

  @@index([ownerId])
}

model RoutineItem {
  id            String   @id @default(cuid())
  routineId     String
  routine       Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exerciseId    String
  exercise      Exercise @relation(fields: [exerciseId], references: [id])
  order         Int
  supersetGroup Int?
  targetSets    Int      @default(3)
  targetRepLow  Int      @default(8)
  targetRepHigh Int      @default(12)
  targetRestSec Int      @default(120)
  targetRpe     Float?
  notes         String?

  @@unique([routineId, order])
}

/// A workout session — serves both the live (ACTIVE) and historical (COMPLETED)
/// states. `sourceSnapshot` freezes the source routine's items at start for diffing.
model WorkoutSession {
  id             String         @id @default(cuid())
  ownerId        String
  owner          User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  routineId      String?
  routine        Routine?       @relation(fields: [routineId], references: [id], onDelete: SetNull)
  sourceSnapshot Json?
  status         SessionStatus  @default(ACTIVE)
  goal           Goal?
  name           String?
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  durationSec    Int?
  bodyweightKg   Float?
  notes          String?
  restTimer      Json?
  entries        SessionEntry[]

  @@index([ownerId, status])
  @@index([ownerId, startedAt])
}

model SessionEntry {
  id                  String   @id @default(cuid())
  sessionId           String
  session             WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId          String
  exercise            Exercise @relation(fields: [exerciseId], references: [id])
  order               Int
  supersetGroup       Int?
  originRoutineItemId String? // null = added mid-workout
  targetSets          Int      @default(3)
  targetRepLow        Int      @default(8)
  targetRepHigh       Int      @default(12)
  targetRestSec       Int      @default(120)
  targetRpe           Float?
  isRemoved           Boolean  @default(false) // soft-remove preserves diff intent
  sets                SetLog[]

  @@unique([sessionId, order])
  @@index([sessionId])
}

model SetLog {
  id          String    @id @default(cuid())
  entryId     String
  entry       SessionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  setIndex    Int
  weightKg    Float?
  reps        Int?
  rpe         Float?
  rir         Int?
  isWarmup    Boolean   @default(false)
  completed   Boolean   @default(false)
  completedAt DateTime?

  @@unique([entryId, setIndex])
}

model PersonalRecord {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  kind       PrKind
  value      Float
  unit       String
  setLogId   String?
  sessionId  String?
  achievedAt DateTime @default(now())

  @@unique([ownerId, exerciseId, kind])
  @@index([ownerId])
}

// ---------------------------------------------------------------------------
// Fatigue & recovery (P6)
// ---------------------------------------------------------------------------

model SorenessReport {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  muscle     Muscle
  severity   Int // 0..10
  reportedAt DateTime @default(now())

  @@index([ownerId, reportedAt])
}

/// Derived cache (rebuildable from SetLog + SorenessReport) of per-muscle fatigue.
model MuscleFatigueSnapshot {
  id            String   @id @default(cuid())
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  muscle        Muscle
  fatigue       Float
  recoveryEtaAt DateTime?
  computedAt    DateTime @default(now())

  @@unique([ownerId, muscle])
}

// ---------------------------------------------------------------------------
// Gamification (P8): XP ledger, stats, leagues, notifications, jobs
// ---------------------------------------------------------------------------

enum XpEventType {
  SET
  PR
  WORKOUT_COMPLETE
  STREAK_DAY
  VOLUME_MILESTONE
  FRIEND_STREAK_BONUS
}

enum LeagueOutcome {
  PROMOTE
  HOLD
  RELEGATE
}

enum CohortStatus {
  ACTIVE
  SETTLED
}

enum NotifKind {
  STREAK_RISK
  LEAGUE_RESULT
  FRIEND_REQUEST
  FRIEND_PR
  WEEKLY_RECAP
  LEVEL_UP
}

enum JobStatus {
  RUNNING
  OK
  FAILED
}

/// Append-only XP ledger — the source of truth for all gamification.
model XpEvent {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       XpEventType
  amount     Int // capped
  rawAmount  Int // pre-cap, for auditing anti-cheese
  workoutId  String?
  meta       Json?
  occurredAt DateTime    @default(now())
  dayKey     String // user-local YYYY-MM-DD
  weekKey    String // user-local ISO week
  createdAt  DateTime    @default(now())

  @@index([userId, dayKey])
  @@index([userId, weekKey])
  @@index([weekKey])
}

/// Denormalized rollup (rebuildable from XpEvent + sessions).
model UserStats {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifetimeXp    Int      @default(0)
  level         Int      @default(1)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveDay String?
  freezesAvail  Int      @default(0)
  totalVolume   BigInt   @default(0) // centi-kg
  totalSessions Int      @default(0)
  leagueTier    String   @default("BRONZE")
  updatedAt     DateTime @updatedAt

  @@index([lifetimeXp])
  @@index([longestStreak])
}

model LeagueCohort {
  id        String       @id @default(cuid())
  tier      String
  weekKey   String
  status    CohortStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  members   LeagueMembership[]

  @@index([weekKey, status])
  @@index([tier, weekKey, status])
}

model LeagueMembership {
  id       String         @id @default(cuid())
  cohortId String
  cohort   LeagueCohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyXp Int            @default(0)
  rank     Int?
  outcome  LeagueOutcome?

  @@unique([cohortId, userId])
  @@index([cohortId, weeklyXp])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotifKind
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

/// Scheduled-job observability + idempotency lock.
model JobRun {
  id         String    @id @default(cuid())
  job        String
  periodKey  String
  status     JobStatus @default(RUNNING)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  detail     Json?

  @@unique([job, periodKey])
}

// ---------------------------------------------------------------------------
// Social (P9): friends, blocks, privacy, activity feed, friend streaks
// ---------------------------------------------------------------------------

enum FriendStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum Visibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum ActivityType {
  PR
  STREAK_MILESTONE
  LEAGUE_PROMOTE
  WORKOUT_DONE
  LEVEL_UP
  FRIEND_STREAK
}

model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User         @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  respondedAt DateTime?

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model PrivacySettings {
  userId             String     @id
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileVisible     Visibility @default(FRIENDS)
  showWorkouts       Visibility @default(FRIENDS)
  showStats          Visibility @default(FRIENDS)
  leaderboardOptIn   Boolean    @default(true)
  activityFeedOptIn  Boolean    @default(true)
  searchableByHandle Boolean    @default(true)
}

model ActivityEvent {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       ActivityType
  meta       Json?
  visibility Visibility   @default(FRIENDS)
  createdAt  DateTime     @default(now())

  @@index([userId, createdAt])
}

/// One row per friend pair (stored ordered: userAId < userBId).
model FriendStreak {
  id         String   @id @default(cuid())
  userAId    String
  userBId    String
  count      Int      @default(0)
  lastDayKey String?
  active     Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

// ---------------------------------------------------------------------------
// Body metrics & progress photos (P10)
// ---------------------------------------------------------------------------

model BodyMetric {
  id           String   @id @default(cuid())
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  recordedAt   DateTime @default(now())
  bodyweightKg Float?
  measurements Json? // { chest, waist, arms, thighs, hips, ... } in cm
  notes        String?

  @@index([ownerId, recordedAt])
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  storageKey String  // file under the uploads volume (outside webroot); never a public path
  width     Int
  height    Int
  takenAt   DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([ownerId, takenAt])
}
