# 1MoreRep — environment template.
# Only pre-database essentials live here; SMTP and LLM/Ollama config are managed
# in the admin panel (stored encrypted in the DB). Generated by install.sh (P3).

NODE_ENV=development
APP_URL=http://localhost:3000

# Host port the Docker stack publishes (what you connect to). Change this to run
# on a different port — e.g. APP_PORT=8080. install.sh also accepts `--port 8080`.
APP_PORT=3000
# Host interface for the published port. Set to 127.0.0.1 when a reverse proxy
# (nginx/Caddy) fronts the app, so the plaintext port isn't exposed publicly.
APP_BIND=0.0.0.0
# Set true when behind a reverse proxy so the app trusts X-Forwarded-For/X-Real-IP.
TRUST_PROXY=false
# In-container listen port — fixed at 3000 for the Docker stack (compose hardcodes
# it); only relevant when running the server directly (node server.js / next start).
PORT=3000

# --- Database ---
POSTGRES_USER=onemorerep
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=onemorerep
DATABASE_URL=postgresql://onemorerep:devpassword@localhost:5432/onemorerep?schema=public

# --- Secrets (generated by install.sh; required in production) ---
# APP_KEY=            # base64 32 bytes — AES-256-GCM key + IP HMAC (the single app secret)

# --- Web Push VAPID (generated by install.sh in P11) ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# --- Bootstrap (consumed by seed; P3) ---
# SUPERADMIN_EMAIL=admin@example.com
